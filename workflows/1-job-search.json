      "id": "f38c2ae0-50c2-449c-ae4b-5e082b6cfb8a",
      "name": "P1: LinkedIn Guest Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1712,
        16
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "amount": 3,
        "unit": "seconds"
      },
      "id": "778954d1-a6a7-4925-a136-6417cb48c4d5",
      "name": "P1: Rate Limit Delay",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
