    {
      "parameters": {
        "jsCode": "// STATELESS PAGINATION CONTROLLER\n// Page number is carried in the input item itself — no static data needed.\n// • When called from P1: Loop Over Keywords (new keyword): _nextPage is absent → page 0\n// • When called from P1: Pagination Step (next page):      _nextPage carries the next page index\n\nconst maxPages = 5;\nconst resultsPerPage = 25;\n\nconst inputItem = $input.first().json;\n\n// Determine page index\nconst pageNum = (inputItem._nextPage !== undefined) ? Number(inputItem._nextPage) : 0;\n\n// Read keyword config — always from the SplitInBatches loop context\n// (this context is pinned for the entire duration of one keyword's page loop)\nconst loopItem = $('P1: Loop Over Keywords').first().json;\nconst keyword         = loopItem.Keyword            || loopItem.keyword            || \"\";\nconst location        = loopItem.Location           || loopItem.location           || \"\";\nconst experienceLevel = String(loopItem['Experience Level'] || loopItem.experience_level || \"\");\nconst remote          = String(loopItem.Remote      || loopItem.remote             || \"\");\nconst jobType         = String(loopItem['Job Type'] || loopItem.job_type           || \"\");\nconst easyApply       = String(loopItem['Easy Apply']|| loopItem.easy_apply        || \"\");\n\n// Stop condition: exceeded page limit\nif (pageNum >= maxPages) {\n  return [{ json: {\n    stop: true,\n    reason: \"Reached maximum page limit of \" + maxPages,\n    url: null,\n    _keyword: keyword,\n    _location: location\n  }}];\n}\n\nconst startOffset = pageNum * resultsPerPage;\nlet url = \"https://www.linkedin.com/jobs/search/?f_TPR=r604800\";\nurl += `&start=${startOffset}`;\n\nif (keyword !== \"\")  url += `&keywords=${encodeURIComponent(keyword)}`;\nif (location !== \"\") url += `&location=${encodeURIComponent(location)}`;\n\nif (experienceLevel !== \"\") {\n  const map = { \"Internship\":\"1\",\"Entry level\":\"2\",\"Associate\":\"3\",\"Mid-Senior level\":\"4\",\"Director\":\"5\",\"Executive\":\"6\" };\n  const vals = experienceLevel.split(\",\").map(e => { let t=e.trim(); return map[t]||( [\"1\",\"2\",\"3\",\"4\",\"5\",\"6\"].includes(t)?t:\"\"); }).filter(Boolean);\n  if (vals.length) url += `&f_E=${vals.join(\",\")}`;\n}\n\nif (remote !== \"\") {\n  const map = { \"On-Site\":\"1\",\"Remote\":\"2\",\"Hybrid\":\"3\" };\n  const vals = remote.split(\",\").map(e => { let t=e.trim(); return map[t]||([\"1\",\"2\",\"3\"].includes(t)?t:\"\"); }).filter(Boolean);\n  if (vals.length) url += `&f_WT=${vals.join(\",\")}`;\n}\n\nif (jobType !== \"\") {\n  const vals = jobType.split(\",\").map(t => t.trim().charAt(0).toUpperCase()).filter(Boolean);\n  if (vals.length) url += `&f_JT=${vals.join(\",\")}`;\n}\n\nif (easyApply === \"true\" || easyApply === \"TRUE\" || easyApply === true) {\n  url += \"&f_AL=true\";\n}\n\nreturn [{ json: {\n  url,\n  stop: false,\n  currentPage: pageNum + 1,   // human-readable (1-based)\n  _nextPage: pageNum + 1,     // machine use: passed forward to pagination step\n  _keyword: keyword,\n  _location: location\n}}];\n"
      },
