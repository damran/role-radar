    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data || '';\n\n// Page number is forwarded from Code in JavaScript via the URL item\n// The URL node is P1: LinkedIn Guest Search whose input came from If\n// which came from Code in JavaScript — read it from that node's output.\nlet keyword = '';\nlet location = '';\nlet currentPage = 1;\ntry {\n  // Code in JavaScript passes keyword/location info via the URL item\n  // which is accessible as the triggering item in the Code node output\n  const codeOut = $('Code in JavaScript').first().json;\n  keyword = codeOut._keyword || '';\n  location = codeOut._location || '';\n  currentPage = codeOut.currentPage || 1;\n} catch(e) {}\n\n// Extract job IDs\nconst ids = [...html.matchAll(/data-entity-urn=\"urn:li:jobPosting:(\\d+)\"/g)].map(m => m[1]);\n\n// Extract titles\nconst titles = [...html.matchAll(/class=\"base-search-card__title\"[^>]*>\\s*([\\s\\S]*?)\\s*<\\/h3>/g)]\n  .map(m => m[1].replace(/<[^>]+>/g, '').trim());\n\n// Extract companies\nconst companies = [...html.matchAll(/class=\"base-search-card__subtitle\"[^>]*>[\\s\\S]*?<a[^>]*>([^<]+)<\\/a>/g)]\n  .map(m => m[1].trim());\n\n// Extract locations\nconst locations = [...html.matchAll(/class=\"job-search-card__location\"[^>]*>\\s*([\\s\\S]*?)\\s*<\\/span>/g)]\n  .map(m => m[1].replace(/<[^>]+>/g, '').trim());\n\n// Extract dates\nconst dates = [...html.matchAll(/datetime=\"([^\"]+)\"/g)].map(m => m[1]);\n\nconst results = [];\nfor (let i = 0; i < ids.length; i++) {\n  if (!ids[i] || !titles[i]) continue;\n  const title = titles[i] || '';\n  const company = companies[i] || '';\n  const postedDate = dates[i] || new Date().toISOString().split('T')[0];\n  const daysOld = postedDate ? Math.floor((Date.now() - new Date(postedDate).getTime()) / 86400000) : 0;\n\n  results.push({\n    json: {\n      job_id: `li_${ids[i]}`,\n      linkedin_id: ids[i],\n      title: title,\n      company: company,\n      location: locations[i] || location,\n      posted_date: postedDate,\n      listing_age_days: daysOld,\n      job_url: `https://www.linkedin.com/jobs/view/${ids[i]}/`,\n      apply_url: `https://www.linkedin.com/jobs/view/${ids[i]}/`,\n      source: 'LinkedIn',\n      search_keyword: keyword,\n      //dedup_key: `${title.toLowerCase().trim().replace(/\\s+/g, '_')}|${company.toLowerCase().trim().replace(/\\s+/g, '_')}`,\n      dedup_key: `${title.toLowerCase().trim().replace(/\\s+/g, '_')}|${company.toLowerCase().trim().replace(/\\s+/g, '_')}|${ids[i]}`,\n      status: 'New',\n      score: '',\n      cv_link: '',\n      cover_letter_link: '',\n      salary_range: '',\n      remote_type: '',\n      company_summary: '',\n      swot_strengths: '',\n      swot_weaknesses: '',\n      swot_opportunities: '',\n      swot_threats: '',\n      matched_skills: '',\n      missing_skills: '',\n      improvement_notes: '',\n      date_found: new Date().toISOString().split('T')[0],\n      _currentPage: currentPage\n    }\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: {\n    job_id: '', title: '', company: '', dedup_key: '', status: 'empty',\n    date_found: new Date().toISOString().split('T')[0],\n    _currentPage: currentPage\n  }}];\n}\nreturn results;\n"
      },
      "id": "2b033fcc-812d-4e88-9945-512271ac4a5f",
      "name": "P1: Parse LinkedIn HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2112,
        16
      ]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData(\"node\");\nconst items = $input.all();\n\n// 1. Initialize persistent runtime memory\nstaticData.seenIds = staticData.seenIds || [];\nconst runtimeSeen = new Set(staticData.seenIds);\n\n// 2. Get data already in the Spreadsheet (Snapshot)\nconst spreadsheetSeen = new Set();\ntry {\n  const existingRows = $(\"P1: Read Existing Job IDs\").all();\n  existingRows.forEach(row => {\n    const d = row.json;\n    if (d.job_id) spreadsheetSeen.add(String(d.job_id));\n    if (d.job_url) spreadsheetSeen.add(String(d.job_url).toLowerCase().trim());\n    if (d.dedup_key) spreadsheetSeen.add(String(d.dedup_key));\n  });\n} catch (e) {\n  // If spreadsheet node hasn't run or is empty, we just skip\n}\n\n// 3. Filter current batch\nconst filtered = items.filter(item => {\n  const job = item.json;\n  if (!job.job_id || job.status === \"empty\") return false;\n\n  const id = String(job.job_id);\n  const url = String(job.job_url || \"\").toLowerCase().trim();\n  const key = String(job.dedup_key || \"\");\n\n  // Check: Is it in the spreadsheet OR seen earlier in this specific run?\n  const isDup = spreadsheetSeen.has(id) || spreadsheetSeen.has(url) || spreadsheetSeen.has(key) ||\n                runtimeSeen.has(id) || runtimeSeen.has(url) || runtimeSeen.has(key);\n\n  if (isDup) return false;\n\n  // Mark as seen for the NEXT keyword in this run\n  runtimeSeen.add(id);\n  if (url) runtimeSeen.add(url);\n  if (key) runtimeSeen.add(key);\n  \n  return true;\n});\n\n// 4. Save runtime memory back (only IDs/Keys to keep it light)\nstaticData.seenIds = Array.from(runtimeSeen);\n\n// 5. Handle empty results safely\nif (filtered.length === 0) {\n  return [{ json: { status: \"no_new_jobs\", _currentPage: items[0]?.json?._currentPage || 1 } }];\n}\n\nreturn filtered;"
      },
