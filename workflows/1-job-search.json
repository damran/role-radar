      "parameters": {
        "jsCode": "// Collapse all inputs into one pagination trigger carrying the next page index.\n// On the \"Save\" branch the Google Sheets append output can drop _currentPage,\n// so we fall back to reading it from the parse node.\nconst allItems = $input.all();\nlet donePage = Number(allItems[0] && allItems[0].json ? allItems[0].json._currentPage : undefined);\nif (!donePage || Number.isNaN(donePage)) {\n  try { donePage = Number($('P1: Parse LinkedIn HTML').first().json._currentPage) || 1; }\n  catch (e) { donePage = 1; }\n}\nreturn [{ json: { _nextPage: donePage, _jobs_processed: allItems.length } }];\n"
      },
