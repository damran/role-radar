    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data || '';\nconst jobData = $('P1.5: Loop Through Jobs').first().json;\n\n// Clean LinkedIn HTML and convert to Markdown\nlet text = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, ' ')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, ' ')\n  .replace(/<br\\s*\\/?>/gi, '\\n')\n  .replace(/<li[^>]*>/gi, '\\n• ')\n  .replace(/<\\/li>/gi, '')\n  .replace(/<h[1-6][^>]*>/gi, '\\n## ')\n  .replace(/<\\/h[1-6]>/gi, '\\n')\n  .replace(/<p[^>]*>/gi, '\\n')\n  .replace(/<\\/p>/gi, '\\n')\n  .replace(/<div[^>]*>/gi, '\\n')\n  .replace(/<\\/div>/gi, '')\n  .replace(/<section[^>]*>/gi, '\\n')\n  .replace(/<\\/section>/gi, '')\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"')\n  // Remove LinkedIn UI junk\n  .replace(/Sign in to access AI-powered advices|Sign in to evaluate your skills/gi, '')\n  .replace(/Email or phone|Password|Forgot password|Join now/gi, '')\n  .replace(/By clicking Continue to join or sign in, you agree to LinkedIn's User Agreement/gi, '')\n  .replace(/Similar jobs[\\s\\S]*?Show (more|fewer) jobs/gi, '')\n  .replace(/People also viewed[\\s\\S]*$/gi, '')\n  .replace(/Referrals increase your chances/gi, '')\n  .replace(/Get notified when a new job is posted/gi, '')\n  .replace(/LinkedIn © \\d{4}/gi, '')\n  .replace(/Show more|Show less/gi, '')\n  .replace(/\\d+ applicants/gi, '')\n  .replace(/See who .* has hired for this role/gi, '')\n  .replace(/Set alert for similar jobs/gi, '')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\n// Build Markdown document\nconst archiveDate = new Date().toISOString().split('T')[0];\nconst markdownContent = `# ${jobData.title || 'Untitled'}\n\n**Company:** ${jobData.company || 'Unknown'}\n**Location:** ${jobData.location || 'Unknown'}\n**Posted:** ${jobData.posted_date || 'Unknown'}\n**Source:** ${jobData.source || 'LinkedIn'}\n**URL:** ${jobData.job_url || ''}\n**Archived:** ${archiveDate}\n\n---\n\n## Job Description\n\n${text}\n\n---\n\n## Metadata\n\n- Job ID: ${jobData.job_id || ''}\n- Search Keyword: ${jobData.search_keyword || 'N/A'}\n- Score: ${jobData.score || 'Not scored'}\n- Status: ${jobData.status || 'Unknown'}\n- Dedup Key: ${jobData.dedup_key || 'N/A'}\n`;\n\n// Create safe filename\nconst safeTitle = (jobData.title || 'job').replace(/[^a-zA-Z0-9\\s]/g, '').replace(/\\s+/g, '_').substring(0, 40);\nconst safeCompany = (jobData.company || 'company').replace(/[^a-zA-Z0-9\\s]/g, '').replace(/\\s+/g, '_').substring(0, 25);\nconst jobIdShort = (jobData.job_id || '').replace('li_', '');\nconst filename = `${archiveDate}__${safeCompany}__${safeTitle}__${jobIdShort}.md`;\n\nreturn [{\n  json: {\n    ...jobData,\n    markdown_content: markdownContent,\n    filename: filename,\n    archived_date: archiveDate\n  }\n}];"
      },
