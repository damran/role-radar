        "jsCode": "const uploadResult = $input.first().json;\nconst jobData = $('P1.5: Merge Folder ID').first().json;\n\nreturn [{\n  json: {\n    job_id: jobData.job_id,\n    title: jobData.title,\n    company: jobData.company,\n    location: jobData.location,\n    posted_date: jobData.posted_date,\n    archived_date: jobData.archived_date,\n    drive_link: uploadResult.webViewLink || uploadResult.webContentLink || '',\n    job_url: jobData.job_url,\n    score: jobData.score || '',\n    status: jobData.status || ''\n  }\n}];"
