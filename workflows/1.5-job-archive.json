    {
      "parameters": {
        "jsCode": "// Get folder ID from either search result or newly created folder\nconst searchResult = $('P1.5: Archive Folder Exists?').first();\nlet folderId = null;\n\nif (searchResult.json.id) {\n  // Folder exists, use it\n  folderId = searchResult.json.id;\n} else {\n  // Folder was just created\n  const createResult = $('P1.5: Create Archive Folder').first();\n  folderId = createResult.json.id;\n}\n\nconst jobData = $('P1.5: Convert HTML to Markdown').first().json;\n\n// Convert markdown content to binary format for Google Drive upload\nconst markdownBuffer = Buffer.from(jobData.markdown_content, 'utf-8');\n\nreturn [{\n  json: {\n    ...jobData,\n    archive_folder_id: folderId\n  },\n  binary: {\n    data: {\n      data: markdownBuffer.toString('base64'),\n      mimeType: 'text/markdown',\n      fileName: jobData.filename,\n      fileExtension: 'md'\n    }\n  }\n}];"
      },
