    {
      "parameters": {
        "jsCode": "// Filter out jobs that are already archived\nconst jobs = $('P1.5: Read Jobs Sheet').all();\nconst archived = $('P1.5: Read Archive Sheet').all();\n\n// Build a Set of archived job_ids for fast lookup\nconst archivedIds = new Set();\narchived.forEach(row => {\n  if (row.json.job_id) {\n    archivedIds.add(String(row.json.job_id).trim());\n  }\n});\n\n// Filter jobs not yet archived\nconst unarchived = jobs.filter(job => {\n  const jobId = String(job.json.job_id || '').trim();\n  return jobId && !archivedIds.has(jobId);\n});\n\nif (unarchived.length === 0) {\n  return [{ json: { message: 'No new jobs to archive', count: 0 } }];\n}\n\nreturn unarchived;"
      },
