# ─────────────────────────────────────────────────────────────
#  OPTIONAL: environment-variable approach
#
#  The recommended setup stores keys in n8n CREDENTIALS (HTTP Header Auth),
#  so you do NOT need this file. It's here only if you prefer 12-factor
#  config and reference keys in expressions as {{ $env.OPENROUTER_API_KEY }}.
#
#  If you use this path, set N8N_BLOCK_ENV_ACCESS_IN_NODE=false on your n8n
#  instance so expressions can read $env, and pass this file to your
#  n8n container (e.g. `env_file: .env` in docker-compose).
#
#  NEVER commit your real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Only needed if you wire a Gemini node back in (the base workflows do not use it)
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Google Sheet + Drive resource IDs
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID
DRIVE_ROOT_FOLDER_ID=YOUR_DRIVE_ROOT_FOLDER_ID
APPLICATIONS_FOLDER_ID=YOUR_APPLICATIONS_FOLDER_ID
ARCHIVE_FOLDER_ID=YOUR_ARCHIVE_FOLDER_ID
